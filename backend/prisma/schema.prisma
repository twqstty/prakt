generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int          @id @default(autoincrement())
  username    String
  email       String       @unique
  password    String
  role        String       @default("USER")
  clubId      Int?
  club        Club?        @relation(fields: [clubId], references: [id], onDelete: SetNull)
  matches     Match[]
  matchRounds MatchRound[]
}

model Club {
  id              Int        @id @default(autoincrement())
  name            String
  city            String
  budget          Int
  rating          Int
  players         Player[]
  managers        User[]
  homeMatches     Match[]    @relation("HomeClub")
  awayMatches     Match[]    @relation("AwayClub")
  transfersFrom   Transfer[] @relation("FromClub")
  transfersTo     Transfer[] @relation("ToClub")
}

model Player {
  id             Int        @id @default(autoincrement())
  name           String
  age            Int
  position       String
  rating         Int
  price          Int
  clubId         Int?
  appearances    Int        @default(0)
  goals          Int        @default(0)
  assists        Int        @default(0)
  yellowCards    Int        @default(0)
  redCards       Int        @default(0)
  injuredUntil   DateTime?
  suspendedUntil DateTime?
  club           Club?      @relation(fields: [clubId], references: [id], onDelete: SetNull)
  transfers      Transfer[]
}

model Match {
  id                Int          @id @default(autoincrement())
  homeClubId        Int
  awayClubId        Int
  homeScore         Int
  awayScore         Int
  homeShots         Int          @default(0)
  awayShots         Int          @default(0)
  homeShotsOnTarget Int          @default(0)
  awayShotsOnTarget Int          @default(0)
  homeXg            Float        @default(0)
  awayXg            Float        @default(0)
  round             Int          @default(0)
  roundId           Int?
  userId            Int?
  matchDate         DateTime
  homeClub          Club         @relation("HomeClub", fields: [homeClubId], references: [id], onDelete: Cascade)
  awayClub          Club         @relation("AwayClub", fields: [awayClubId], references: [id], onDelete: Cascade)
  matchRound        MatchRound?  @relation(fields: [roundId], references: [id], onDelete: SetNull)
  user              User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  events            MatchEvent[]
}

model MatchRound {
  id        Int      @id @default(autoincrement())
  number    Int
  userId    Int?
  matchDate DateTime
  createdAt DateTime @default(now())
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  matches   Match[]

  @@unique([userId, number])
}

model MatchEvent {
  id       Int    @id @default(autoincrement())
  matchId  Int
  playerId Int?
  minute   Int
  type     String
  clubName String
  player   String
  detail   String?
  match    Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
}

model Transfer {
  id           Int      @id @default(autoincrement())
  playerId     Int
  fromClubId   Int?
  toClubId     Int
  price        Int
  transferDate DateTime @default(now())
  player       Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  fromClub     Club?    @relation("FromClub", fields: [fromClubId], references: [id], onDelete: SetNull)
  toClub       Club     @relation("ToClub", fields: [toClubId], references: [id], onDelete: Cascade)
}
